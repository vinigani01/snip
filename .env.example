# Copy this to .env and fill in your values

# Port the container exposes (default 3000)
PORT=3000

# Public base URL for generated short links.
# Change this to your Render URL or custom domain after deploying.
BASE_URL=http://localhost:3000

# Postgres connection string.
# On Render this is set automatically. For local dev, use a local Postgres instance:
# DATABASE_URL=postgresql://user:password@localhost:5432/urlshort
DATABASE_URL=
